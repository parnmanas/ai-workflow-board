# docker-compose 용 환경변수 (.env로 복사해서 사용)
DB_NAME=ai_workflow
DB_USER=postgres
DB_PASS=your-secure-password-here

# Required in production: stable secret used to derive the AES-256-GCM key
# that encrypts Credential rows (provider tokens, API keys). Without this the
# server falls back to writing a key file under /app/database, which is not
# writable by the container user and breaks credential save with EACCES.
# Generate once and keep stable across deploys — losing it makes every stored
# credential undecryptable. Example: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-a-long-random-secret
