# docker-compose 용 환경변수 (.env로 복사해서 사용)
DB_NAME=ai_workflow
DB_USER=postgres
DB_PASS=your-secure-password-here

# Optional: stable secret used to derive the AES-256-GCM key that encrypts
# Credential rows (provider tokens, API keys). If unset the server
# auto-generates a key file under the awbdata volume (compose handles this).
# Set this only if you want to manage the key yourself — e.g. rotate it or
# share it across replicas. Losing the configured value (or the awbdata
# volume) makes every stored credential undecryptable.
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=replace-with-a-long-random-secret
