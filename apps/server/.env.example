# ──────────────────────────────────────────
# AI Workflow Board - Server Configuration
# ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Server ────────────────────────────────
PORT=7701

# ── Database ──────────────────────────────
# sqlite (default for local dev) | postgres | mysql
DB_TYPE=sqlite

# Postgres / MySQL settings (ignored when DB_TYPE=sqlite)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_workflow
DB_USER=postgres
DB_PASS=

# ── MCP Authentication ────────────────────
# Comma-separated API keys for MCP endpoint.
# Format: agentName:key,agentName2:key2  (or just key,key2)
# Leave empty to run in dev mode (no auth required).
MCP_API_KEYS=

# ── Agent API ─────────────────────────────
# Shared secret for agent-to-server API calls
AGENT_API_KEY=
