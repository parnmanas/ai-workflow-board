{
  "name": "ai-workflow-board",
  "private": true,
  "packageManager": "npm@11.6.1",
  "workspaces": ["apps/*"],
  "scripts": {
    "predev": "node scripts/clear-ports.mjs",
    "dev": "turbo run dev",
    "dev:server": "turbo run dev --filter=server",
    "dev:client": "turbo run dev --filter=client",
    "dev:agent-manager": "turbo run dev --filter=agent-manager",
    "clear-ports": "node scripts/clear-ports.mjs",
    "build": "turbo run build",
    "build:agent-manager": "turbo run build --filter=agent-manager",
    "start": "npm start -w server",
    "start:agent-manager": "npm run start -w agent-manager",
    "mcp": "npm run mcp -w server",
    "mcp:http": "npm run mcp:http -w server"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "overrides": {
    "@nestjs/swagger": {
      "js-yaml": "^4.2.0"
    },
    "@angular-devkit/core": {
      "picomatch": "^4.0.4"
    },
    "fdir": {
      "picomatch": "^4.0.4"
    },
    "vite": {
      "picomatch": "^4.0.4"
    }
  }
}
